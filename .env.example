# Blanck Capital OS — environment template
#
# 1. Copy this file:     cp .env.example .env.local
# 2. Fill in any keys you have — others keep their seed fallbacks.
# 3. Restart the dev server (or click "restart" in StackBlitz).
#
# Every key is OPTIONAL. The app ships with realistic seed data for every
# widget. Keys below flip the widget to live-feed mode on next render.

# --- Economic data ---------------------------------------------------------
# FRED API (CPI-YoY, Fed Funds, single-obs series)
# Sign up — instant, free, no credit card: https://fred.stlouisfed.org/docs/api/api_key.html
VITE_FRED_API_KEY=

# --- Market data -----------------------------------------------------------
# Polygon.io (indexes + top gainers/losers + ticker snapshots)
# Free tier covers the homepage widgets: https://polygon.io/pricing
VITE_POLYGON_API_KEY=

# --- Events + news ---------------------------------------------------------
# Finnhub (earnings calendar, IPO calendar, US stocks news)
# Free tier: https://finnhub.io/dashboard
VITE_FINNHUB_API_KEY=

# --- Prediction markets (SexyBot / Kash) -----------------------------------
# Kalshi read-only session — https://trading-api-docs.kalshi.com
VITE_KALSHI_EMAIL=
VITE_KALSHI_PASSWORD=

# Polymarket CLOB is fully public; set to "1" to enable the reader.
VITE_POLYMARKET_READONLY=

# --- Banking (future) ------------------------------------------------------
# Plaid — used to back the Single-Source institution table once wired.
# These go on the BACKEND, never here. Do not expose them to the browser.
# VITE_PLAID_PUBLIC_ENV=sandbox
