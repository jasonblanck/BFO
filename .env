# Blanck Capital OS — committed API keys
#
# All VITE_* vars become part of the client bundle at build time, so treat
# everything here as public. FRED is explicitly public-safe; Polygon /
# Finnhub are gated by soft per-key rate limits. Rotate via the provider
# dashboard at any time.

# FRED (fred.stlouisfed.org) — inflation, Fed Funds, macro series
VITE_FRED_API_KEY=b7cb93e3c892cc4408be7637499b85ed

# Polygon.io — indexes + top gainers/losers snapshots
VITE_POLYGON_API_KEY=

# Finnhub — earnings, IPO, news
VITE_FINNHUB_API_KEY=

# SexyBot / Kash (prediction markets)
VITE_KALSHI_EMAIL=
VITE_KALSHI_PASSWORD=
VITE_POLYMARKET_READONLY=
